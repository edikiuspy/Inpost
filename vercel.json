{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pnpm install",
  "buildCommand": "pnpm frontend:build",
  "outputDirectory": "frontend/dist",
  "functions": {
    "api/**/*.py": {
      "excludeFiles": "{.git/**,.vercel/**,.venv/**,node_modules/**,frontend/**,backend/tests/**,backend/data/**,.pytest_cache/**,**/__pycache__/**,*.sqlite3,*.sqlite3-journal,*.log,docker-compose.yml}"
    }
  },
  "rewrites": [
    {
      "source": "/docs",
      "destination": "/api/index.py"
    },
    {
      "source": "/openapi.json",
      "destination": "/api/index.py"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/(.*)",
      "destination": "/$1"
    }
  ]
}
